NODE_ENV=production
PORT=5000

# ─── Database (RDS) ─────────────────────────────────────────────
# Full connection string (recommended for RDS)
DATABASE_URL=postgresql://postgres:CHANGE_ME@tnp-postgres.xxxx.ap-south-1.rds.amazonaws.com:5432/tnp_platform

# Enable SSL for RDS
DB_SSL=true

# ─── Auth ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_EXPIRES_IN=7d

# ─── AWS ────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME

# S3 bucket for student documents & resumes
S3_BUCKET_NAME=CHANGE_ME_your-docs-bucket-name

# SES — sender address (must be verified in SES)
SES_FROM_EMAIL=noreply@CHANGE_ME.com
# Optional: SES configuration set for tracking
# SES_CONFIGURATION_SET=tnp-email-tracking

# ─── CORS ───────────────────────────────────────────────────────
# Set this after CloudFront distribution is created
FRONTEND_URL=https://CHANGE_ME.cloudfront.net
